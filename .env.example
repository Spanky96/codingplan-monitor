# ===== GLM 用量监控 配置 =====
# 用法:复制本文件为 .env 并按需修改   cp .env.example .env
# .env 已加入 .gitignore,不会提交(含密码等敏感信息)。

# 服务监听端口
PORT=4000

# 监听地址(0.0.0.0 = 允许局域网访问)
HOST=0.0.0.0

# 管理密码(账号增删改、Key 复制/创建/删除需校验)—— 请务必修改!
ADMIN_PASSWORD=123456

# 账号数据文件路径
#   本地运行留空即可,默认使用项目根目录下的 ./accounts.json
#   Docker 部署时由 docker-compose.yml 指定为 /app/data/accounts.json 以持久化
# ACCOUNTS_FILE=/app/data/accounts.json

# 运行环境(development / production)
NODE_ENV=production

# 智云抓取所用浏览器路径；macOS 和 Docker 可自动发现，其他环境按需设置
# TELECOMJS_CHROME_PATH=/usr/bin/chromium
